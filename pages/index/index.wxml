<!--index.wxml-->
<view class="container">
  <view class="userinfo">
    <button wx:if="{{!hasUserInfo}}" bindtap="handleGetUserProfile" loading="{{authStatus === 'loading'}}">Get avatar and nickname</button>
    <text wx:if="{{authErrorMessage}}" class="userinfo-error">{{authErrorMessage}}</text>
    <block wx:else>
      <image bindtap="bindViewTap" class="userinfo-avatar" src="{{userInfo.avatarUrl}}" mode="cover"></image>
      <text class="userinfo-nickname">{{userInfo.nickName}}</text>
    </block>
  </view>
  <view class="usermotto">
    <text class="user-motto">{{motto}}</text>
  </view>
</view>
